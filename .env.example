# ─────────────────────────────────────────────────────────────
# ECOM API (Go) — environment template
# Copy to .env.local / .env.dev / .env.prod and edit values.
# These vars are consumed by docker-compose and injected into containers.
# ─────────────────────────────────────────────────────────────

# Docker image tag
API_TAG=local

# ── Databases (one per service) ──────────────────────────────
CATALOG_DB=catalog_db
CATALOG_DB_USER=catalog
CATALOG_DB_PASSWORD=catalog

ORDER_DB=order_db
ORDER_DB_USER=orderuser
ORDER_DB_PASSWORD=orderpass

PAYMENT_DB=payment_db
PAYMENT_DB_USER=paymentuser
PAYMENT_DB_PASSWORD=paymentpass

# ── Cache (Redis) ────────────────────────────────────────────
# Shared cache-aside layer (pkg/cache). Leave REDIS_ADDR empty to disable
# caching entirely — services still run, just without the cache layer.
# docker-compose injects REDIS_ADDR=redis:6379 into each service for you.
REDIS_ADDR=
REDIS_PASSWORD=
REDIS_DB=0

# ── Auth ─────────────────────────────────────────────────────
# Shared JWT signing secret verified by every service (pkg/auth).
JWT_SECRET=dev-secret-change-me

# ── pgAdmin ──────────────────────────────────────────────────
PGADMIN_EMAIL=admin@ecom.dev
PGADMIN_PASSWORD=admin

# ── Prod-only image overrides (used by docker-compose.prod.yml) ──
# CATALOG_IMAGE=ghcr.io/your-org/ecom-catalog
# ORDER_IMAGE=ghcr.io/your-org/ecom-order
# PAYMENT_IMAGE=ghcr.io/your-org/ecom-payment
# CATALOG_REPLICAS=2
# ORDER_REPLICAS=2
# PAYMENT_REPLICAS=2
