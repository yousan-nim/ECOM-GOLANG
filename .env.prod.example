# Production env template — copy to .env.prod and set strong secrets.
# All *_USER / *_PASSWORD are required (compose uses :? to fail fast if unset).

# Databases (one per service)
CATALOG_DB=catalog_db
CATALOG_DB_USER=__set_me__
CATALOG_DB_PASSWORD=__set_me_strong__

ORDER_DB=order_db
ORDER_DB_USER=__set_me__
ORDER_DB_PASSWORD=__set_me_strong__

PAYMENT_DB=payment_db
PAYMENT_DB_USER=__set_me__
PAYMENT_DB_PASSWORD=__set_me_strong__

# Auth
JWT_SECRET=__set_me_strong__

# Images pulled from your registry
CATALOG_IMAGE=ghcr.io/your-org/ecom-catalog
ORDER_IMAGE=ghcr.io/your-org/ecom-order
PAYMENT_IMAGE=ghcr.io/your-org/ecom-payment
API_TAG=latest

# Replicas per service
CATALOG_REPLICAS=2
ORDER_REPLICAS=2
PAYMENT_REPLICAS=2

# pgAdmin (enable with --profile admin)
PGADMIN_EMAIL=admin@ecom.dev
PGADMIN_PASSWORD=__set_me_strong__
